# .env.example — copy this file to .env and fill in your values
# cp .env.example .env
#
# NEVER commit .env — it is gitignored.
# This file (.env.example) IS committed so colleagues know exactly what to fill in.

# ─────────────────────────────────────────────
# Lucid REST API — OAuth 2.0 Authorization Code Flow
# ─────────────────────────────────────────────
# Obtain these from the Lucid Developer Portal:
# https://lucid.app/developer
#
# You must pre-register the redirect URI below in the portal
# under your OAuth client's "Redirect URIs" setting before
# the Authorization Code flow will work.

LUCID_CLIENT_ID=your_client_id_here
LUCID_CLIENT_SECRET=your_client_secret_here

# Must match exactly what is registered in the Lucid Developer Portal.
# Default for local development: http://localhost:8000/callback
LUCID_REDIRECT_URI=http://localhost:8000/callback

# Space-separated OAuth scopes to request.
# Valid values: account.user, account.user:readonly, user.profile,
#               lucidchart.document.content, offline_access, etc.
# See full list: https://developer.lucid.co/reference/access-scopes
# For read-only user lookups: account.user:readonly user.profile
# For user creation too:      account.user user.profile
LUCID_OAUTH_SCOPES=account.user:readonly user.profile

# Account token OAuth flow — for account-admin endpoints (createUser, listUsers)
# Uses https://lucid.app/oauth2/authorizeAccount instead of /authorize.
# You MUST also register http://localhost:8000/callback-account in the
# Lucid Developer Portal under your OAuth client's Redirect URIs.
LUCID_ACCOUNT_REDIRECT_URI=http://localhost:8000/callback-account
LUCID_ACCOUNT_OAUTH_SCOPES=account.user

# ─────────────────────────────────────────────
# Lucid SCIM API — Static Bearer Token
# ─────────────────────────────────────────────
# Generate this token in the Lucid Admin Panel:
# Admin Panel → Security → API Tokens → Create Token
#
# This token is long-lived and does not expire automatically.
# Rotate it by generating a new one in the Admin Panel.

LUCID_SCIM_TOKEN=your_scim_bearer_token_here

# ─────────────────────────────────────────────
# Anthropic API — Claude narrative generation
# ─────────────────────────────────────────────
# Obtain your API key from: https://console.anthropic.com
# All Claude calls are routed through app/services/ai_client.py only.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
# Port the Uvicorn server listens on. Default: 8000.
PORT=8000

# Enable debug mode (uvicorn --reload, verbose logging). Default: true.
DEBUG=true

# ─────────────────────────────────────────────
# MCP Server — no credentials needed here
# ─────────────────────────────────────────────
# The Lucid MCP server uses Dynamic Client Registration (DCR).
# The mcp Python package handles registration programmatically at runtime.
# No MCP client_id or client_secret goes in this file.
