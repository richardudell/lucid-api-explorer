# .env.demo — demo-safe local config (no real secrets)
#
# Usage:
#   cp .env.demo .env
#   python scripts/doctor.py --demo
#   python main.py
#
# In this mode:
#   - App boots for UI walkthroughs.
#   - OAuth/SCIM/AI calls require real credentials and will surface clear
#     config/auth errors instead of crashing startup.

APP_ENV=demo
DEMO_MODE=true

LUCID_CLIENT_ID=__DEMO_CLIENT_ID__
LUCID_CLIENT_SECRET=__DEMO_CLIENT_SECRET__
LUCID_REDIRECT_URI=http://localhost:8000/callback
LUCID_ACCOUNT_REDIRECT_URI=http://localhost:8000/callback-account
LUCID_OAUTH_SCOPES=account.user:readonly user.profile
LUCID_ACCOUNT_OAUTH_SCOPES=account.user

LUCID_SCIM_TOKEN=__DEMO_SCIM_DISABLED__
ANTHROPIC_API_KEY=__DEMO_AI_DISABLED__

PORT=8000
DEBUG=true
